PORT=8080
APP_ENV=development
DATABASE_URL=postgres://postgres:postgres@postgres:5432/go_lang?sslmode=disable
JWTSecret=change-me-to-a-long-random-secret-at-least-32-bytes
ACCESS_TOKEN_TTL=15m
BcryptCost=10

READ_HEADER_TIMEOUT=5s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
MAX_HEADER_BYTES=1048576
MAX_BODY_BYTES=1048576
SHUTDOWN_TIMEOUT=15s

# REDIS_URL=redis://localhost:6379/0
USER_CACHE_TTL=5m

# When REDIS_URL is set, the rate limiter switches to a Redis-backed
# implementation that shares buckets across replicas. Leave it
# commented to use the in-memory limiter (per-instance, lost on
# restart).
# KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=go-rest-api.events
KAFKA_WRITE_TIMEOUT=10s

RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_BURST=40
AUTH_RATE_LIMIT_PER_SECOND=5
AUTH_RATE_LIMIT_BURST=10

# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

IDEMPOTENCY_TTL=24h
